NODE_ENV="development"

POSTGRES_HOST="localhost"
POSTGRES_PORT="5432" # Needs to match the port in docker-compose.yml
POSTGRES_NAME="mydb"
POSTGRES_USER="username"
POSTGRES_PASSWORD="password"

DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_NAME}?schema=public"

REDIS_HOST="localhost"
REDIS_PORT="6379" # Needs to match the port in docker-compose.yml
REDIS_USERNAME=""
REDIS_PASSWORD=""

CORS_ORIGINS="http://localhost:5173,http://localhost:3000,http://localhost:4200"

# Production (Render dashboard — set manually):
# DATABASE_URL        — auto from Postgres if linked in render.yaml
# REDIS_HOST/PORT     — auto from Redis if linked in render.yaml
# CORS_ORIGINS        — your frontend URL, e.g. https://your-board.onrender.com